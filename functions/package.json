{
  "name": "global-mailer-functions",
  "version": "1.0.0",
  "description": "Firebase Cloud Functions for Global Mailer",
  "scripts": {
    "build": "tsc",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "dependencies": {
    "firebase-admin": "^11.11.1",
    "firebase-functions": "^7.2.5",
    "imapflow": "^1.3.2",
    "nodemailer": "^6.10.1",
    "resend": "^6.12.2"
  },
  "devDependencies": {
    "@types/nodemailer": "^6.4.23",
    "typescript": "^5.9.3"
  },
  "private": true
}
