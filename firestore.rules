rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Kontakty - len pre autentifikovaných používateľov
    match /contacts/{contactId} {
      allow read, write: if request.auth != null;
    }
    
    // SMTP nastavenia - len pre autentifikovaných používateľov
    match /settings/{settingId} {
      allow read, write: if request.auth != null;
    }
    
    // Email štatistiky - len pre autentifikovaných používateľov
    match /stats/{statId} {
      allow read, write: if request.auth != null;
    }
    
    // Email logy - len pre autentifikovaných používateľov
    match /email_logs/{logId} {
      allow read, write: if request.auth != null;
    }
  }
}
